{
  "name": "ai-traffic-lights",
  "version": "0.6.6",
  "description": "Overlay com um semáforo 🟢🟡🔴 por sessão de agente de IA no desktop — Claude Code, Antigravity, Codex e OpenCode via adapters",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox --disable-dev-shm-usage",
    "setup-hook": "node scripts/setup-hook.js",
    "remove-hook": "node scripts/setup-hook.js --remove",
    "hook:test": "bash hooks/traffic-hook.sh",
    "test": "node --test",
    "dist": "electron-builder --linux"
  },
  "author": "Aron Peyroteo <aronpeyroteo@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/aronpc/ai-traffic-lights",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aronpc/ai-traffic-lights.git"
  },
  "bugs": {
    "url": "https://github.com/aronpc/ai-traffic-lights/issues"
  },
  "build": {
    "appId": "dev.aitrafficlights.app",
    "productName": "AI Traffic Lights",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "hooks/**/*",
      "adapters/**/*",
      "assets/tray-icon*.png",
      "build/icon.png"
    ],
    "publish": {
      "provider": "github",
      "owner": "aronpc",
      "repo": "ai-traffic-lights"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "build/icon.png",
      "synopsis": "Traffic light overlay for terminal AI agent sessions",
      "executableArgs": [
        "--no-sandbox",
        "--disable-dev-shm-usage"
      ]
    }
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "electron-updater": "^6.8.9"
  }
}
